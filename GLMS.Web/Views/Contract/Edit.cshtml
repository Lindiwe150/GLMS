@model Contract
@{ ViewData["Title"] = "Edit Contract"; }

<h2>Edit Contract</h2>
<form asp-action="Edit" method="post" enctype="multipart/form-data" class="mt-3" style="max-width:550px">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="SignedAgreementPath" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="ClientId" class="form-label">Client</label>
        <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="ServiceLevel" class="form-label"></label>
        <input asp-for="ServiceLevel" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-select"
                asp-items="Html.GetEnumSelectList<ContractStatus>()"></select>
    </div>
    <div class="mb-3">
        <label class="form-label">Replace Signed Agreement (PDF only, optional)</label>
        <input type="file" name="signedAgreement" accept=".pdf" class="form-control" />
        @if (Model.SignedAgreementPath != null)
        {
            <small class="text-muted">Current: @System.IO.Path.GetFileName(Model.SignedAgreementPath)</small>
        }
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
