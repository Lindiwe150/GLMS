@model Contract
@{ ViewData["Title"] = "Contract Details"; }

<h2>Contract Details</h2>
<dl class="row mt-3">
    <dt class="col-sm-3">Client</dt><dd class="col-sm-9">@Model.Client?.Name</dd>
    <dt class="col-sm-3">Service Level</dt><dd class="col-sm-9">@Model.ServiceLevel</dd>
    <dt class="col-sm-3">Start Date</dt><dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">End Date</dt><dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Signed Agreement</dt>
    <dd class="col-sm-9">
        @if (Model.SignedAgreementPath != null)
        {
            <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-info">📄 Download PDF</a>
        }
        else { <span>None uploaded</span> }
    </dd>
</dl>

<h4 class="mt-4">Service Requests</h4>
@if (!Model.ServiceRequests.Any())
{
    <p class="text-muted">No service requests yet.</p>
}
else
{
    <table class="table table-sm">
        <thead><tr><th>Description</th><th>Cost (USD)</th><th>Cost (ZAR)</th><th>Status</th></tr></thead>
        <tbody>
        @foreach (var sr in Model.ServiceRequests)
        {
            <tr>
                <td>@sr.Description</td>
                <td>$@sr.CostUsd.ToString("N2")</td>
                <td>R @sr.CostZar.ToString("N2")</td>
                <td>@sr.Status</td>
            </tr>
        }
        </tbody>
    </table>
}
<a asp-action="Index" class="btn btn-secondary mt-2">Back</a>
