@model ServiceRequest
@{ ViewData["Title"] = "Service Request Details"; }

<h2>Service Request Details</h2>
<dl class="row mt-3">
    <dt class="col-sm-3">Contract</dt><dd class="col-sm-9">@Model.Contract?.ServiceLevel</dd>
    <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Description</dd>
    <dt class="col-sm-3">Cost (USD)</dt><dd class="col-sm-9">$@Model.CostUsd.ToString("N2")</dd>
    <dt class="col-sm-3">Cost (ZAR)</dt><dd class="col-sm-9">R @Model.CostZar.ToString("N2")</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Created</dt><dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>
<a asp-action="Index" class="btn btn-secondary">Back</a>
