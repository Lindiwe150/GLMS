@model ServiceRequest
@{ ViewData["Title"] = "New Service Request"; }

<h2>New Service Request</h2>
<p class="text-muted">Current rate: <strong>1 USD = R <span id="rateDisplay">@ViewBag.UsdToZarRate</span></strong></p>

<form asp-action="Create" method="post" class="mt-3" style="max-width:550px">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="ContractId" class="form-label">Contract (Active only)</label>
        <select asp-for="ContractId" asp-items="ViewBag.Contracts" class="form-select">
            <option value="">-- Select Contract --</option>
        </select>
        <span asp-validation-for="ContractId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CostUsd" class="form-label">Cost (USD)</label>
        <input asp-for="CostUsd" id="costUsd" type="number" step="0.01" min="0" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Estimated Cost (ZAR)</label>
        <input id="costZarDisplay" type="text" class="form-control" readonly placeholder="Auto-calculated" />
        <input asp-for="CostZar" type="hidden" id="costZarHidden" />
    </div>
    <button type="submit" class="btn btn-primary">Submit Request</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>

@section Scripts {
<script>
    const rate = @ViewBag.UsdToZarRate;
    document.getElementById('costUsd').addEventListener('input', function () {
        const usd = parseFloat(this.value) || 0;
        const zar = (usd * rate).toFixed(2);
        document.getElementById('costZarDisplay').value = 'R ' + zar;
        document.getElementById('costZarHidden').value = zar;
    });
</script>
}
