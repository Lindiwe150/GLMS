@model IEnumerable<ServiceRequest>
@{ ViewData["Title"] = "Service Requests"; }

<h2>Service Requests <a asp-action="Create" class="btn btn-primary btn-sm ms-2">+ New</a></h2>
<table class="table table-striped mt-3">
    <thead><tr><th>Contract</th><th>Description</th><th>Cost (USD)</th><th>Cost (ZAR)</th><th>Status</th><th>Created</th><th></th></tr></thead>
    <tbody>
    @foreach (var sr in Model)
    {
        <tr>
            <td>@sr.Contract?.ServiceLevel</td>
            <td>@sr.Description</td>
            <td>$@sr.CostUsd.ToString("N2")</td>
            <td>R @sr.CostZar.ToString("N2")</td>
            <td>@sr.Status</td>
            <td>@sr.CreatedAt.ToString("yyyy-MM-dd")</td>
            <td>
                <a asp-action="Details" asp-route-id="@sr.Id" class="btn btn-sm btn-outline-primary">View</a>
                <a asp-action="Delete" asp-route-id="@sr.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
